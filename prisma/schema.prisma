generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  emailVerified   DateTime?
  image           String?
  password        String?
  currency        String    @default("GBP")
  weeklyGoal      Decimal   @default(60.00)
  fiscalYearStart Int       @default(1)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  accounts        Account[]
  earnings        Earning[]
  goals           Goal[]
  sessions        Session[]
  uploads         Upload[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Earning {
  id              String    @id @default(cuid())
  userId          String
  studyTitle      String
  completionCode  String?
  status          String
  reward          Float
  rewardCurrency  String    @default("GBP")
  bonus           Float     @default(0)
  bonusCurrency   String?
  totalEarning    Float
  normalizedGBP   Float?
  normalizedUSD   Float?
  startedAt       DateTime?
  completedAt     DateTime?
  durationMinutes Float?
  hourlyRate      Float?
  source          String    @default("manual")
  uploadId        String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  upload          Upload?   @relation(fields: [uploadId], references: [id])
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, startedAt, studyTitle])
  @@index([userId, startedAt])
  @@index([userId, status])
  @@index([userId, createdAt])
}

model Upload {
  id             String    @id @default(cuid())
  userId         String
  fileName       String
  fileType       String
  fileSize       Int
  recordCount    Int       @default(0)
  importedCount  Int       @default(0)
  duplicateCount Int       @default(0)
  errorCount     Int       @default(0)
  status         String    @default("processed")
  errorMessage   String?
  createdAt      DateTime  @default(now())
  earnings       Earning[]
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Goal {
  id        String    @id @default(cuid())
  userId    String
  name      String
  type      String
  target    Float
  currency  String    @default("GBP")
  startDate DateTime?
  endDate   DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}
